# ═══════════════════════════════════════════════════
# CLAUSTOR AI — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════

# ── APP ──────────────────────────────────────────
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# ── DATABASE (Neon PostgreSQL) ───────────────────
DATABASE_URL=postgresql://neondb_owner:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_TEST=postgresql://neondb_owner:password@ep-xxx.us-east-1.aws.neon.tech/neondb_test?sslmode=require

# ── REDIS (Upstash) ──────────────────────────────
REDIS_URL=rediss://default:password@choice-marten-185834.upstash.io:6379

# ── VECTOR DB (Pinecone) ─────────────────────────
PINECONE_API_KEY=pcsk_xxxx
PINECONE_INDEX=claustor-contracts
PINECONE_HOST=claustor-contracts-xxxx.svc.aped-xxxx.pinecone.io

# ── MESSAGE QUEUE ────────────────────────────────
# Free/Starter: uses Redis (RABBITMQ_URL empty)
# Pro/Enterprise: uses RabbitMQ
RABBITMQ_URL=amqps://user:password@leopard.lmq.cloudamqp.com/vhost

# ── FILE STORAGE (GCS) ───────────────────────────
GCP_PROJECT=contract-intelligence-p2
GCP_REGION=asia-south1
GCS_BUCKET_CONTRACTS=claustor-contracts
GCS_BUCKET_CACHE=claustor-cache
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json  # local only

# ── AUTH (Auth0) ──────────────────────────────────
AUTH0_DOMAIN=dev-xxxx.us.auth0.com
AUTH0_CLIENT_ID=xxxx
AUTH0_CLIENT_SECRET=xxxx
AUTH0_SECRET=run-openssl-rand-hex-32-to-generate   # openssl rand -hex 32
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://dev-xxxx.us.auth0.com

# JWT (internal service auth)
JWT_SECRET_KEY=run-openssl-rand-hex-32-to-generate
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM PROVIDERS ────────────────────────────────
# Set keys for providers you want to use
# Leave empty to disable that provider
# Fallback chain: GROQ → GEMINI → OPENAI

GROQ_API_KEY=gsk_xxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

GEMINI_API_KEY=AIzaSy_xxxx
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MODEL_PRO=gemini-1.5-pro

OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4o-mini

OLLAMA_HOST=                      # http://localhost:11434 for on-premise
OLLAMA_MODEL=llama3.3:70b

# ── EMAIL (Resend) ────────────────────────────────
RESEND_API_KEY=re_xxxx
RESEND_FROM=hello@claustor.com
RESEND_FROM_NAME=Claustor AI

# ── BILLING (Stripe / Razorpay - TBD) ───────────
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxx

# ── MONITORING ────────────────────────────────────
LANGSMITH_API_KEY=xxxx
LANGSMITH_PROJECT=claustor-ai
SENTRY_DSN=https://xxxx@sentry.io/xxxx
